# ── Copy this file to ".env" and fill in your real values ──

# Port the backend + dashboard are served on
PORT=3000

# Scrape Creators API key (https://scrapecreators.com) — sent as the x-api-key header
SCRAPECREATORS_API_KEY=

# NVIDIA NIM / build.nvidia.com API key — used for the sentiment/intent analysis
NVIDIA_API_KEY=

# NVIDIA model + endpoint (defaults match the old n8n workflow)
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Google Sheet that holds the Brand list + stores results
# (same sheet the n8n workflow used)
SPREADSHEET_ID=1ZIR6LbydR_JZR-o06ifp37GeYaOr6hu0gaibQ2C6lO4

# Tab names inside that spreadsheet
SHEET_BRANDS=Brand
SHEET_RAW=Raw_Data
SHEET_INSIGHTS=AI_Insights

# Path to the Google service-account JSON key file.
# Share the spreadsheet with the service account's client_email (Editor access).
GOOGLE_CREDENTIALS_PATH=./credentials/service-account.json
